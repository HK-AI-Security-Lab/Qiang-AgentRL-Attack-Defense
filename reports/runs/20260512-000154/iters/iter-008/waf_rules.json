{
  "block_patterns": [
    "[;&|`$()\\\\n]",
    "{{.*}}",
    "{%.*%}",
    "__.*__",
    "globals",
    "builtins"
  ],
  "ssrf_allowed_schemes": [
    "https"
  ],
  "ssrf_allowed_hosts": [
    "localhost",
    "127.0.0.1"
  ],
  "path_traversal_block": true,
  "sqli_parameterized": true,
  "ssti_sandbox": true,
  "pickle_disabled": true
}